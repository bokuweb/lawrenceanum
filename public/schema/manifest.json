{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema/manifest.json",
  "title": "Manifest",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "files"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "bytes",
          "content_type"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "content_type": {
            "type": "string"
          }
        }
      }
    }
  }
}